#define _POSIX_C_SOURCE 200809L
#include <fcntl.h>
#include <stdint.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <termios.h>
#include <unistd.h>
#include <sys/ioctl.h>

#define HIDE              "\033[?25l"
#define UP                "\033[A"
#define NUP               "\033[%huA"
#define DOWN              "\033[B"
#define NDOWN             "\033[%huB"
#define CLEAR             "\033[0J"
#define SCROLL_VIEW       "\033[%hu;%hur"
#define SCROLL_VIEW_RESET "\033[r"
#define SCROLL_UP         "\033[1S"
#define SCROLL_DOWN       "\033[1T"
#define GOTO_LINE         "\033[%hu;1H"

/* Init the tty descriptor, the terminal size
 * and the current cursor position */
int32_t _tty;
uint16_t _x, _y;
uint16_t _width, _height;

/** Update the current cursor position
 * @returns 0 if all is OK; -1 on error
 */
static int32_t curupdate(void);

/** Move cursor to one line up
 */
static void goup(void);

/** Move cursor to n lines up
 * @param n The number of lines
 */
static void gonup(uint16_t n);

/** Move cursor to one line down
 */
static void godown(void);

/** Move cursor to n lines down
 * @param n The number of lines
 */
static void gondown(uint16_t n);

/** Draw the initial scene
 * @param scene The type of scene to draw
 */
static int32_t draw(enum Scene scene, const char* title);

/** Exit the canon terminal mode
 * @param fd The file descriptor to enable the non-canon mode
 */
static void exit_canon(int32_t fd);

int32_t main(const int32_t argc, const char* const* argv) {
    /* Check for the main argument */
    if (argc < 2) {
        fprintf(stderr, RED"Error: not all the arguments have been passed\n"
                        "See: %s --help\n", argv[0]);
        return -1;
    }

    /* Get the title argument */
    const char* const title = argc == 3 ? argv[2] : NULL;

    /* Draw the scene according to the scene type */
    if (strcmp(argv[1], "checklist") == 0) return draw(CHECKLIST, title);
    else {
        fprintf(stderr, RED"Error: invalid first argument\n"
                        "See: %s --help\n", argv[0]);
        return -1;
    }

    fprintf(stderr, RED"Error: unknown error\n");
    return 0;
}

static int32_t curupdate(void) {
    dprintf(_tty, "\033[6n");
    fflush(stdout);
    char result_buffer[16];
    if (read(_tty, result_buffer, sizeof(result_buffer) - 1) == -1) {
        fprintf(stderr, RED"Error: failed to get the cursor position\n");
        return -1;
    }
    if (sscanf(result_buffer, "\033[%hu;%hu", &_y, &_x) != 2) {
        fprintf(stderr, RED"Error: bad cursor position reply\n");
        return -1;
    }
    return 0;
}

static void goup(void) { dprintf(_tty, UP); --_y; }

static void gonup(const uint16_t n) {  dprintf(_tty, NDOWN, n); _y += n; }

static void godown(void) { dprintf(_tty, DOWN); ++_y; }

static void gondown(const uint16_t n) {  dprintf(_tty, NDOWN, n); _y += n; }

static int32_t draw(const enum Scene scene, const char* const title) {
    /* Open the tty descriptor */
    _tty = open("/dev/tty", O_RDWR);
    if (_tty == -1) {
        fprintf(stderr, RED"Error: failed to open the tty descriptor\n");
        return -1;
    } else exit_canon(_tty);

    /* Hide the cursor */
    dprintf(_tty, HIDE);

    {
        /* Get the terminal size */
        struct winsize ws;
        if (ioctl(_tty, TIOCGWINSZ, &ws) == -1) {
            fprintf(stderr, RED"Error: failed to get the window size\n");
            return -1;
        } else { _width = ws.ws_col; _height = ws.ws_row; }
    }

    if (scene == CHECKLIST) {
        /* Print the title */
        if (title == NULL) dprintf(_tty, PURPLE"Choose:\n");
        else dprintf(_tty, PURPLE"%s:\n", title);

        /* Alloc the memory for option names */
        int32_t names_off= 0;
        int32_t names_size = 128;
        char* names = malloc(names_size);
        if (names == NULL) {
            fprintf(stderr, RED"Error: can't allocate the memory\n");
            return -1;
        }

        /* Alloc the memory for option descs */
        int32_t descs_off= 0;
        int32_t descs_size = 128;
        char* descs = malloc(descs_size);
        if (descs == NULL) {
            fprintf(stderr, RED"Error: can't allocate the memory\n");
            return -1;
        }

        /* Alloc the memory for option descs */
        int16_t stats_off= 0;
        int16_t stats_size = 1;
        bool* stats = malloc(names_size);
        if (stats == NULL) {
            fprintf(stderr, RED"Error: can't allocate the memory\n");
            return -1;
        }

        /* Init buffers to store the data */
        char name_buffer[128];
        char desc_buffer[1024];
        char stat_buffer[8];

        /* Save the number of the options */
        uint16_t opts_num = 0;

        /* Print choose options from the STDIN */
        bool is_first_option = true;
        for (;;) {
            /* Read an option */
            if (fgets(name_buffer, sizeof(name_buffer), stdin) == NULL) break;
            if (fgets(desc_buffer, sizeof(desc_buffer), stdin) == NULL) break;
            if (fgets(stat_buffer, sizeof(stat_buffer), stdin) == NULL) break;

            /* Get the pointer to the end of the every buffer */
            char* name_buffer_end =
                memchr(name_buffer, '\n', sizeof(name_buffer));
            char* desc_buffer_end =
                memchr(desc_buffer, '\n', sizeof(desc_buffer));
            char* stat_buffer_end =
                memchr(stat_buffer, '\n', sizeof(stat_buffer));
            if (name_buffer_end == NULL ||
                desc_buffer_end == NULL ||
                stat_buffer_end == NULL) {
                fprintf(stderr, RED"Error: too large input:\n"
                                "%s\n",
                                name_buffer_end == NULL ? name_buffer :
                                desc_buffer_end == NULL ? desc_buffer :
                                stat_buffer);
                return -1;
            }

            /* Remove \n chars */
            *name_buffer_end = '\0';
            *desc_buffer_end = '\0';
            *stat_buffer_end = '\0';

            /* Save the name to the dynamic array */
            const uint16_t name_len = name_buffer_end - name_buffer;
            while (name_len + names_off > names_size) {
                names_size *= 2;
                names = realloc(names, names_size);
                if (names == NULL) {
                    fprintf(stderr, RED"Error: can't allocate the memory\n");
                    return -1;
                }
            }
            memcpy(names + names_off, name_buffer, name_len + 1);
            names_off += name_len + 1;

            /* Save the desc to the dynamic array */
            const uint16_t desc_len = desc_buffer_end - desc_buffer;
            while (desc_len + descs_off > descs_size) {
                descs_size *= 2;
                descs = realloc(descs, descs_size);
                if (descs == NULL) {
                    fprintf(stderr, RED"Error: can't allocate the memory\n");
                    return -1;
                }
            }
            memcpy(descs + descs_off, desc_buffer, desc_len + 1);
            descs_off += desc_len + 1;

            /* Check the stat */
            bool enabled = strcmp(stat_buffer, "ON") == 0;

            /* Save the stat to the dynamic array */
            if (stats_off >= stats_size) {
                stats_size *= 2;
                stats = realloc(stats, stats_size);
                if (stats == NULL) {
                    fprintf(stderr, RED"Error: can't allocate the memory\n");
                    return -1;
                }
            }
            stats[stats_off] = enabled;
            ++stats_off;

            /* Increase the number of options */
            ++opts_num;
        }

        /* Create an array for storing all the option names */
        const char* names_org[opts_num];
        const char* names_ptr = names;
        for (uint16_t i = 0; i < opts_num; ++i) {
            names_org[i] = names_ptr;
            names_ptr = strchr(names_ptr, '\0');
            if (names_ptr == NULL) {
                fprintf(stderr, RED"Error: memory corrupt\n");
                return -1;
            } else ++names_ptr;
        }

        /* Create an array for storing all the option descs */
        const char* descs_org[opts_num];
        const char* descs_ptr = descs;
        for (uint16_t i = 0; i < opts_num; ++i) {
            descs_org[i] = descs_ptr;
            descs_ptr = strchr(descs_ptr, '\0');
            if (descs_ptr == NULL) {
                fprintf(stderr, RED"Error: memory corrupt\n");
                return -1;
            } else ++descs_ptr;
        }

#define REDRAW_LINE(S)                                                         \
        dprintf(tty, "\r  %s %s - %s"S,                                        \
                stats[current_index] ? BLUE"✓" : WHITE"•",                     \
                names_org[current_index], descs_org[current_index]);
#define REDRAW_CLINE(S)                                                        \
        dprintf(tty, FONT(BOLD, ITALIC, BLUE)"\r> %s %s - %s"S,                \
                stats[current_index] ? "✓" : "•",                              \
                names_org[current_index], descs_org[current_index]);
#define NGOTO(DIR, N)                                                          \
        dprintf(tty, "\r  %s %s - %s"DIR,                                      \
                stats[current_index] ? BLUE"✓" : WHITE"•",                     \
                names_org[current_index], descs_org[current_index], N);

        /* Print the options */
        uint16_t current_index = 0;
        const uint16_t free_height = _height - 6;
        const bool scrollable = free_height < opts_num;
        const uint16_t cur_opts_num = scrollable ? free_height : opts_num;
        if (cur_opts_num > 0) { REDRAW_CLINE("\n"); ++current_index; }
        for (uint16_t i = 1; i < cur_opts_num; ++i) {
            REDRAW_LINE("\n"); ++current_index;
        }

        /* Print the key bindings */
        dprintf(tty, "\n"
                FONT(BRIGHT_BLACK, BOLD)"X/Space "GREY"toggle   "
                FONT(BRIGHT_BLACK, BOLD)"hjkl "GREY"navigate   "
                FONT(BRIGHT_BLACK, BOLD)"Enter "GREY"submit   "
                FONT(BRIGHT_BLACK, BOLD)"Ctrl+A "GREY"toggle all\n"
                FONT(BRIGHT_BLACK, BOLD)"/       "GREY"find     "
                FONT(BRIGHT_BLACK, BOLD)"N    "GREY"next       "
                FONT(BRIGHT_BLACK, BOLD)"P     "GREY"prev     "
                FONT(BRIGHT_BLACK, BOLD)"F      "GREY"filter");

        /* Get the end position */
        if (curupdate() == -1) return -1;
        const uint16_t checklist_end = _y;

        /* If the checkbox is scrollable */
        const uint16_t top_end = _y - cur_opts_num - 1;
        const uint16_t bottom_end = _y - 3;
        if (scrollable) dprintf(_tty, SCROLL_VIEW, top_end - 1, bottom_end);

        /* Move the cursor to the first option and reset the current index */
        current_index = 0; dprintf(_tty, GOTO_LINE, top_end - 1);
        if (curupdate() == -1) return -1;

        /* Read the input */
        uint8_t input;
        for (;;) {
            /* Get the input */
            if (read(_tty, &input, 1) == -1) {
                fprintf(stderr, RED"Error: failed to read the /dev/tty\n");
                return -1;
            }

            /* Check for <Escape> and 'q' */
            if (input == 27 || input == 'q') {
                /* Clear the scene */
                dprintf(tty, SCROLL_VIEW_RESET RESET);
                gonup(_y + 3 - top_end);
                dprintf(_tty, CLEAR);
                return -1;
            }

            /* Check for Enter */
            if (input == '\n') break;

            /* Handle navigation keys */
            if (input == 'k') {
                /* Check for the current index */
                if (current_index <= 0) continue;

                /* Do not point to the old option and go up */
                REDRAW_LINE();

                /* Align the cursor */
                if (_y < top_end) dprintf(_tty, SCROLL_DOWN);
                else goup();

                /* Decrease the current index */
                --current_index;
            } else if (input == 'j') {
                /* Check for the current index */
                if (current_index + 1 >= opts_num) continue;

                /* Do not point to the old option and go down */
                REDRAW_LINE();

                /* Align the cursor */
                if (_y >= bottom_end) dprintf(_tty, SCROLL_UP);
                else godown();

                /* Increase the current index */
                ++current_index;
            } else if (input == 'h') {
                while (current_index != 0) {
                    /* Redraw lines */
                    REDRAW_LINE();
                    --current_index;

                    /* Align the cursor */
                    if (_y < top_end) dprintf(_tty, SCROLL_DOWN);
                    else goup();
                }
            } else if (input == 'l') {
                const uint16_t max_index = opts_num - 1;
                while (current_index < max_index) {
                    /* Redraw lines */
                    REDRAW_LINE();
                    ++current_index;

                    /* Align the cursor */
                    if (_y >= bottom_end) dprintf(_tty, SCROLL_UP);
                    else godown();
                }
            }

            /* Handle toggle keys */
            else if (input == 'x' || input == ' ') stats[current_index] ^= 1;

            /* Handle Ctrl+A */
            else if (input == 1) {
                /* Save the old index and reset the current */
                const uint16_t old_index = current_index;

                /* Save the old y pos */
                const uint16_t old_y = _y;

                /* Get the state which we will use
                 * (default - true; if all are flagged - false) */
                bool state = false; for (uint16_t i = 0; i < opts_num; ++i)
                { if (!stats[i]) { state = true; break; } }

                /* Apply the state to all the options */
                current_index = 0;
                do { stats[current_index] = state; }
                while (++current_index < opts_num);

                /* Redraw the screen */
                dprintf(_tty, GOTO_LINE, top_end - 1);
                if (curupdate() == -1) return -1;
                current_index = old_index - (old_y - (top_end - 1));
                const uint16_t max_index = current_index + cur_opts_num - 1;
                do {
                    if (current_index != old_index) { REDRAW_LINE("\n"); }
                    else godown();
                } while (++current_index < max_index);
                REDRAW_LINE();

                /* Restore the old cursor pos and the old index */
                current_index = old_index;
                if (curupdate() == -1) return -1;
                gonup(bottom_end - old_y);
            }

            /* Redraw the current line */
            REDRAW_CLINE();
            fflush(stdout);
        }

        /* Clear the scene */
        dprintf(tty, SCROLL_VIEW_RESET RESET);
        gonup(_y + 3 - top_end);
        dprintf(_tty, CLEAR);

        /* Print all the flagged elements */
        for (uint16_t i = 0; i < opts_num; ++i)
            if (stats[i]) printf("%s\n", names_org[i]);

        /* Return the success code */
        return 0;
    }

    /* Exit with the error code and the error message */
    fprintf(stderr, RED"Error: unknown error\n");
    return -1;
}

static void exit_canon(const int32_t fd) {
    /* Save the current terminal settings */
    struct termios term;
    tcgetattr(fd, &term);

    /* Disable the canon mode and echo */
    term.c_lflag &= ~(ICANON | ECHO);

    /* Read char by char without any timeout */
    term.c_cc[VMIN] = 1;
    term.c_cc[VTIME] = 0;

    /* Apply the new terminal settings */
    tcsetattr(fd, TCSANOW, &term);
}
